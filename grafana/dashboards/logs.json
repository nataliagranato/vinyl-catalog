{
  "id": null,
  "uid": "vinyl-logs",
  "title": "Vinyl Catalog — Logs",
  "description": "Logs agregados via Loki + Promtail com correlação de traces",
  "tags": ["vinyl-catalog", "logs", "loki"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "hide": 2,
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki"
      },
      {
        "hide": 2,
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      },
      {
        "name": "service",
        "label": "Serviço",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "query": "label_values(service)",
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "app", "value": "app" },
        "hide": 0,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "log_level",
        "label": "Nível",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "query": "label_values({service=~\"$service\"}, log_level)",
        "includeAll": true,
        "allValue": ".+",
        "hide": 0,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Erros (última 1h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "sum(count_over_time({service=\"app\", log_level=\"ERROR\"}[1h]))",
        "refId": "A",
        "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 10 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 2,
      "title": "Warnings (última 1h)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "sum(count_over_time({service=\"app\", log_level=\"WARN\"}[1h]))",
        "refId": "A",
        "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "orange", "value": 20 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3,
      "title": "Total de Linhas (última 1h)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "sum(count_over_time({service=~\"$service\"}[1h]))",
        "refId": "A",
        "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4,
      "title": "Volume de Logs por Nível",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum by (log_level) (count_over_time({service=\"app\", log_level=~\".+\"}[2m]))",
          "legendFormat": "{{log_level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ERROR" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" }}]
          },
          {
            "matcher": { "id": "byName", "options": "WARN" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" }}]
          },
          {
            "matcher": { "id": "byName", "options": "INFO" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" }}]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 5,
      "title": "Logs — app",
      "description": "Logs da aplicação. Clique no trace_id para abrir o trace no Jaeger.",
      "type": "logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 14 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "{service=\"app\", log_level=~\"$log_level\"} | json",
        "refId": "A"
      }],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 6,
      "title": "Logs — Todos os Serviços",
      "description": "Logs de todos os containers do stack.",
      "type": "logs",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [{
        "expr": "{service=~\"$service\"}",
        "refId": "A"
      }],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }
  ]
}
